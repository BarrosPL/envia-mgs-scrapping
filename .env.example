# Copie este arquivo para .env e preencha localmente.
# Se a senha tiver caracteres especiais (@, :, /, # etc.), codifique-os na URL.
DATABASE_URL=postgresql+psycopg://usuario:senha@postgres:5432/nome_do_banco?sslmode=disable

# Geração de mensagens para os leads da planilha
OPENAI_API_KEY=cole_sua_chave_aqui
OPENAI_MODEL=gpt-5.6-luna
CUSTOMER_SERVICE_URL=https://seu-link-de-atendimento.example

# Produção no EasyPanel
APP_MODE=worker
TZ=America/Sao_Paulo
RUN_TIME=10:00
RUN_ON_START=false
DAILY_SEND_LIMIT=15
BATCH_SIZE=15
MIN_CONFIDENCE=80
MIN_DELAY_SECONDS=45
MAX_DELAY_SECONDS=90
BROWSER_PROFILE_DIR=/data/browser-data
DRY_RUN=true

# Necessária somente enquanto APP_MODE=login. Use o modo login temporariamente.
VNC_PASSWORD=troque_esta_senha

# Opcional: endpoint que aceite JSON no formato {"text": "mensagem"}
ALERT_WEBHOOK_URL=
